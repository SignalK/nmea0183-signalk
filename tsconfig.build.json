{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "reports",
    ".stryker-tmp",
    "test",
    "src/bench",
    "src/custom-sentence-plugin"
  ]
}
